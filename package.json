{
  "name": "war-conquista",
  "version": "1.0.0",
  "description": "WAR - Juego de estrategia y conquista de territorios. Multijugador local en el navegador. Desplegado en Cloudflare Pages.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test \"tests/**/*.test.js\"",
    "test:watch": "node --test --watch \"tests/**/*.test.js\"",
    "build:map": "node scripts/build-map-shapes.mjs",
    "dev": "wrangler pages dev . --do GameRoom=./functions/game-room.js",
    "deploy": "wrangler pages deploy .",
    "db:create": "wrangler d1 create war-scores",
    "db:init": "wrangler d1 execute war-scores --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute war-scores --remote --file=./schema.sql"
  },
  "keywords": [
    "juego",
    "estrategia",
    "war",
    "risk",
    "cloudflare-pages"
  ],
  "license": "MIT",
  "devDependencies": {
    "d3-geo": "^3.1.1",
    "d3-geo-projection": "^4.0.0",
    "ethers": "^6.16.0",
    "pixi.js": "^8.19.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "wrangler": "^4.0.0"
  }
}
