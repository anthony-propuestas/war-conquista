{
  "name": "war-conquista",
  "version": "1.0.0",
  "description": "WAR - Juego de estrategia y conquista de territorios. Multijugador local en el navegador. Desplegado en Cloudflare Pages.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test \"tests/**/*.test.js\"",
    "test:watch": "node --test --watch \"tests/**/*.test.js\"",
    "build:map": "node scripts/build-map-shapes.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:do": "wrangler dev --config worker/wrangler.toml --port 8787",
    "dev:pages": "wrangler pages dev . --do GAME_ROOM=GameRoom@war-game-room --port 8788",
    "deploy:worker": "wrangler deploy --config worker/wrangler.toml",
    "deploy": "wrangler pages deploy .",
    "db:create": "wrangler d1 create war-scores"
  },
  "keywords": [
    "juego",
    "estrategia",
    "war",
    "risk",
    "cloudflare-pages"
  ],
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "d3-geo": "^3.1.1",
    "d3-geo-projection": "^4.0.0",
    "pixi.js": "^8.19.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2",
    "wrangler": "^4.0.0"
  }
}
